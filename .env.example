# Required — Flask session security (use a long random string in production)
SECRET_KEY=your-secret-key-here

# Required — PostgreSQL connection string (auto-set by Render when using their database)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Required for AI features — get your key at https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here
